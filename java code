                );

                ps.setString(1, item.getText());
                ps.setInt(2, Integer.parseInt(qty.getText()));
                ps.executeUpdate();

                invModel.setRowCount(0);
                loadInventory();

            } catch (Exception ex) {
                JOptionPane.showMessageDialog(this, ex.getMessage());
            }
        });

        top.add(item);
        top.add(qty);
        top.add(add);

        p.add(top, BorderLayout.NORTH);
        p.add(new JScrollPane(table), BorderLayout.CENTER);

        return p;
    }

    void loadInventory() {
        try {
            Connection con = connect();
            if (con == null) return;
            ResultSet rs = con.createStatement().executeQuery("SELECT * FROM inventory");

            while (rs.next()) {
                invModel.addRow(new Object[]{
                    rs.getInt("item_id"),
                    rs.getString("item_name"),
                    rs.getInt("quantity")
                });
            }

        } catch (Exception e) {}
    }

    // ================= APPOINTMENTS =================
    DefaultTableModel appModel;

    JPanel appointmentPanel() {

        JPanel p = new JPanel(new BorderLayout());

        appModel = new DefaultTableModel(
            new String[]{"ID","Pet","Vet","Date"},0
        );

        JTable table = new JTable(appModel);

        loadAppointments();

        JPanel top = new JPanel();

        JTextField pet = new JTextField(5);
        JTextField vet = new JTextField(5);
        JTextField date = new JTextField(10);

        JButton add = new JButton("Add");

        add.addActionListener(e -> {
            try {
                Connection con = connect();

                PreparedStatement ps = con.prepareStatement(
                    "INSERT INTO appointments(pet_id, vet_id, appointment_date) VALUES(?,?,?)"
                );

                ps.setInt(1, Integer.parseInt(pet.getText()));
                ps.setInt(2, Integer.parseInt(vet.getText()));
                ps.setString(3, date.getText());

                ps.executeUpdate();

                appModel.setRowCount(0);
                loadAppointments();

            } catch (Exception ex) {
                JOptionPane.showMessageDialog(this, ex.getMessage());
            }
        });

        top.add(pet);
        top.add(vet);
        top.add(date);
        top.add(add);

        p.add(top, BorderLayout.NORTH);
        p.add(new JScrollPane(table), BorderLayout.CENTER);

        return p;
    }

    void loadAppointments() {
        try {
            Connection con = connect();
            if (con == null) return;
            ResultSet rs = con.createStatement().executeQuery("SELECT * FROM appointments");

            while (rs.next()) {
                appModel.addRow(new Object[]{
                    rs.getInt("appointment_id"),
                    rs.getInt("pet_id"),
                    rs.getInt("vet_id"),
                    rs.getString("appointment_date")
                });
            }

        } catch (Exception e) {}
    }

