    // ================= USER MANAGEMENT =================
    DefaultTableModel userModel;

    JPanel userManagementPanel() {

        JPanel p = new JPanel(new BorderLayout());

        userModel = new DefaultTableModel(new String[]{"ID", "Username", "Role", "Created At"}, 0);
        JTable table = new JTable(userModel);

        loadUsers();

        JPanel top = new JPanel();

        JButton refreshBtn = new JButton("Refresh Data");
        refreshBtn.addActionListener(e -> loadUsers());

        JButton deleteBtn = new JButton("Delete Select User");
        deleteBtn.addActionListener(e -> {
            int row = table.getSelectedRow();
            if (row != -1) {
                int id = (int) table.getValueAt(row, 0);
                String role = table.getValueAt(row, 2).toString();
                String username = table.getValueAt(row, 1).toString();

                if(role.equals("admin") && currentUser.equals(username)) {
                    JOptionPane.showMessageDialog(this, "You cannot delete your own admin account.");
                    return;
                }

                int confirm = JOptionPane.showConfirmDialog(this, "Are you sure you want to delete user: " + username + "?");
                if (confirm == JOptionPane.YES_OPTION) {
                    try {
                        Connection con = connect();
                        PreparedStatement ps = con.prepareStatement("DELETE FROM users WHERE user_id=?");
                        ps.setInt(1, id);
                        ps.executeUpdate();
                        loadUsers(); // refresh automatically
                    } catch (Exception ex) {
                        JOptionPane.showMessageDialog(this, ex.getMessage());
                    }
                }
            } else {
                JOptionPane.showMessageDialog(this, "Please select a user to delete.");
            }
        });

        top.add(refreshBtn);
        top.add(deleteBtn);

        p.add(top, BorderLayout.NORTH);
        p.add(new JScrollPane(table), BorderLayout.CENTER);

        return p;
    }

    void loadUsers() {
        if (userModel == null) return;
        try {
            Connection con = connect();
            if (con == null) return;
            userModel.setRowCount(0); // clear
            ResultSet rs = con.createStatement().executeQuery(
                "SELECT user_id, username, role, created_at FROM users"
            );

            while (rs.next()) {
                userModel.addRow(new Object[]{
                    rs.getInt("user_id"),
                    rs.getString("username"),
                    rs.getString("role"),
                    rs.getString("created_at")
                });
            }

        } catch (Exception e) {}
    }

