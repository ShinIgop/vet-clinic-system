    void loadClients() {
        if(clientModel == null) return;
        try {
            Connection con = connect();
            if(con == null) return;
            clientModel.setRowCount(0);
            ResultSet rs = con.createStatement().executeQuery("SELECT client_id, full_name, phone, email FROM clients");
            while (rs.next()) {
                clientModel.addRow(new Object[]{
                    rs.getInt("client_id"),
                    rs.getString("full_name"),
                    rs.getString("phone"),
                    rs.getString("email")
                });
            }
        } catch (Exception e) {}
    }

