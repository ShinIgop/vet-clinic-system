    // ================= LOGIN LOGIC =================
    void login() {
        String shortTerms = "TailWise Vet Clinic System – Terms & Conditions\n\n" +
                            "By logging in, you agree to use this system for authorized clinic purposes only.\n\n" +
                            "All data must be kept confidential in accordance with the Data Privacy Act of 2012.\n" +
                            "Unauthorized access, sharing, or misuse of information is strictly prohibited.\n\n" +
                            "The system is provided “as is,” and the developer is not liable for data loss or incorrect entries.\n\n" +
                            "Proceed only if you agree to these terms.";
                            
        JTextArea textArea = new JTextArea(shortTerms);
        textArea.setEditable(false);
        textArea.setLineWrap(true);
        textArea.setWrapStyleWord(true);
        JScrollPane scrollPane = new JScrollPane(textArea);
        scrollPane.setPreferredSize(new Dimension(350, 150));
        
        int confirm = JOptionPane.showConfirmDialog(this, scrollPane, "Terms & Conditions", JOptionPane.OK_CANCEL_OPTION, JOptionPane.WARNING_MESSAGE);
        
        if (confirm != JOptionPane.OK_OPTION) {
            return; // Cancel login if they don't accept
        }

        try {
            Connection con = connect();

            PreparedStatement ps = con.prepareStatement(
                "SELECT role FROM users WHERE username=? AND password=?"
            );

            ps.setString(1, user.getText());
            ps.setString(2, new String(pass.getPassword()));

            ResultSet rs = ps.executeQuery();

            if (rs.next()) {
                currentUser = user.getText();
                currentRole = rs.getString("role");

                // Automatically record the login instance into login_logs
                try {
                    PreparedStatement psLog = con.prepareStatement(
                        "INSERT INTO login_logs(username) VALUES(?)"
                    );
                    psLog.setString(1, currentUser);
                    psLog.executeUpdate();
                } catch(Exception ignored) {}

                // Initialize role-specific dashboard and add to main card layout
                main.add(dashboardUI(), "dash");
                card.show(main, "dash");

            } else {
                JOptionPane.showMessageDialog(this, "Invalid Login");
            }

        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, e.getMessage());
        }
    }

